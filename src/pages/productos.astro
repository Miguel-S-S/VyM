---
import { supabase } from '../lib/supabase';

// Traemos los productos, sus recetas y calculamos todo
const { data: productos } = await supabase
  .from('productos')
  .select(`
    *,
    receta_producto (
      cantidad_necesaria,
      materiales (nombre, costo_unitario, costo_flete)
    )
  `)
  .order('nombre');
---

<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>V&M - Productos</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-50 p-4 md:p-10">
    <div class="max-w-6xl mx-auto">
        <a href="/" class="text-blue-600 font-bold hover:underline mb-4 inline-block">← Volver a Insumos</a>
        <h1 class="text-4xl font-extrabold text-slate-900 mb-8">Catálogo de Productos Finales</h1>

        <div class="bg-white p-6 rounded-xl shadow-sm border border-slate-200 mb-8">
            <h2 class="text-lg font-bold mb-4 text-slate-700">Crear Elemento Deportivo</h2>
            <form id="producto-form" class="grid grid-cols-1 md:grid-cols-4 gap-4">
                <input type="text" id="nombre" placeholder="Nombre (ej: Bolsa de 10kg)" class="border p-2 rounded col-span-2" required />
                <input type="number" step="0.01" id="precio_venta" placeholder="Precio Venta ($)" class="border p-2 rounded" required />
                <input type="number" id="minutos_confeccion" placeholder="Minutos de Confección" class="border p-2 rounded border-orange-300 bg-orange-50" required />
                <button type="submit" class="bg-green-600 text-white font-bold py-2 rounded col-span-full md:col-span-1 hover:bg-green-700 transition">
                    Guardar Producto
                </button>
            </form>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {productos?.map((prod) => {
                const costoProduccion = prod.receta_producto?.reduce((acc, item) => {
                    const totalMaterial = (item.materiales.costo_unitario + item.materiales.costo_flete) * item.cantidad_necesaria;
                    return acc + totalMaterial;
                }, 0);

                return (
                    <div class="bg-white p-6 rounded-xl shadow-sm border border-slate-200 relative">
                        <span class="absolute top-4 right-4 bg-orange-100 text-orange-800 text-xs font-bold px-2 py-1 rounded">
                            ⏱️ {prod.minutos_confeccion || 0} min
                        </span>
                        
                        <h2 class="text-xl font-bold text-slate-800 pr-12">{prod.nombre}</h2>
                        
                        <ul class="mt-4 text-sm text-slate-600 min-h-[100px]">
                            {prod.receta_producto?.length > 0 ? prod.receta_producto.map((item) => (
                                <li class="flex justify-between border-b py-1">
                                    <span>{item.materiales.nombre} (x{item.cantidad_necesaria})</span>
                                    <span>${((item.materiales.costo_unitario + item.materiales.costo_flete) * item.cantidad_necesaria).toFixed(2)}</span>
                                </li>
                            )) : <li class="text-slate-400 italic">No tiene insumos asignados. Ve a Recetas.</li>}
                        </ul>

                        <div class="mt-4 pt-4 border-t flex justify-between items-center">
                            <span class="font-bold text-sm text-slate-500">Costo Total:</span>
                            <span class="text-2xl font-black text-slate-900">${costoProduccion?.toFixed(2)}</span>
                        </div>
                    </div>
                )
            })}
        </div>
    </div>

    <script>
        import { supabase } from '../lib/supabase';
        const form = document.getElementById('producto-form');
        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            const nombre = document.getElementById('nombre').value;
            const precio_venta = parseFloat(document.getElementById('precio_venta').value);
            const minutos_confeccion = parseInt(document.getElementById('minutos_confeccion').value);

            const { error } = await supabase.from('productos').insert([{ 
                nombre, precio_venta, minutos_confeccion 
            }]);
            
            if (!error) location.reload();
        });
    </script>
</body>
</html>