---
// ¡ESTA ES LA LÍNEA MÁGICA QUE SOLUCIONA EL ERROR!
export const prerender = false; 

import { supabase } from '../../lib/supabase';

// 1. Obtenemos el ID de la URL
const { id } = Astro.params;

// 2. Buscamos los datos de ESTE producto específico
const { data: producto, error } = await supabase
  .from('productos')
  .select(`
    *,
    receta_producto (
      cantidad_necesaria,
      materiales (nombre, unidad_medida, costo_unitario, costo_flete)
    )
  `)
  .eq('id', id)
  .single();

// Si el ID no existe en la base de datos, lo mandamos al inicio
if (!producto || error) {
    return Astro.redirect('/');
}

// 3. Calculamos el costo en tiempo real
const costoTotal = producto.receta_producto?.reduce((acc, item) => {
    const totalMaterial = (item.materiales.costo_unitario + item.materiales.costo_flete) * item.cantidad_necesaria;
    return acc + totalMaterial;
}, 0) || 0;
---

<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>{producto.nombre} - V&M Deportes</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-50 p-6 md:p-12">
    <div class="max-w-3xl mx-auto">
        <a href="/productos" class="text-blue-600 font-bold hover:underline mb-6 inline-block">← Volver al Catálogo</a>
        
        <div class="bg-white shadow-xl rounded-2xl overflow-hidden border border-slate-100">
            <div class="p-8 md:p-10">
                <div class="flex justify-between items-start">
                    <div>
                        <h1 class="text-4xl font-black text-slate-900">{producto.nombre}</h1>
                        <p class="text-slate-500 mt-2 text-lg">Elemento de confección propia.</p>
                    </div>
                    <div class="text-right">
                        <span class="block text-sm font-bold text-slate-400 uppercase tracking-wider">Precio de Venta</span>
                        <span class="text-3xl font-black text-green-600">${producto.precio_venta}</span>
                    </div>
                </div>
                
                <div class="grid grid-cols-2 gap-4 mt-8">
                    <div class="p-4 bg-slate-50 rounded-xl border border-slate-100">
                        <span class="text-xs text-slate-500 font-bold uppercase">Costo de Fabricación</span>
                        <p class="text-2xl font-black text-slate-800">${costoTotal.toFixed(2)}</p>
                    </div>
                    <div class="p-4 bg-orange-50 rounded-xl border border-orange-100">
                        <span class="text-xs text-orange-600 font-bold uppercase">Tiempo de Confección</span>
                        <p class="text-2xl font-black text-orange-800">{producto.minutos_confeccion} min</p>
                    </div>
                </div>

                <h3 class="font-bold text-lg mt-10 mb-4 border-b pb-2 text-slate-700">Ficha Técnica de Insumos:</h3>
                <ul class="divide-y divide-slate-100">
                    {producto.receta_producto?.map((item) => (
                        <li class="py-3 flex justify-between items-center hover:bg-slate-50 px-2 rounded transition">
                            <span class="font-medium text-slate-700">{item.materiales.nombre}</span>
                            <div class="text-right">
                                <span class="block text-slate-900 font-bold">{item.cantidad_necesaria} {item.materiales.unidad_medida}</span>
                                <span class="text-xs text-slate-400">
                                    Costo: ${((item.materiales.costo_unitario + item.materiales.costo_flete) * item.cantidad_necesaria).toFixed(2)}
                                </span>
                            </div>
                        </li>
                    ))}
                </ul>
                
                <button class="w-full mt-10 bg-slate-900 hover:bg-slate-800 text-white font-bold py-4 rounded-xl text-lg transition shadow-lg">
                    Añadir al Carrito 🛒
                </button>
            </div>
        </div>
    </div>
</body>
</html>